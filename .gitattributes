# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks bash on Linux/Mac
*.sh text eol=lf

# PowerShell is Windows-only — CRLF is fine
*.ps1 text eol=crlf

# Markdown and config — LF
*.md text eol=lf
*.mdc text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
